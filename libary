				local DropFrame = Instance.new("Frame"); DropFrame.Size = UDim2.new(1, 0, 0, 34); DropFrame.BackgroundTransparency = 1; DropFrame.ClipsDescendants = true; DropFrame.Parent = ItemContainer
				local TopBtn = Instance.new("TextButton"); TopBtn.Size = UDim2.new(1, 0, 0, 34); AddTheme(TopBtn, "BackgroundColor3", "Inactive"); TopBtn.Text = ""; TopBtn.AutoButtonColor = false; TopBtn.Parent = DropFrame; Instance.new("UICorner", TopBtn).CornerRadius = UDim.new(0, 6); local DStroke = Instance.new("UIStroke"); AddTheme(DStroke, "Color", "Border"); DStroke.Parent = TopBtn
				local Title = Instance.new("TextLabel"); Title.Size = UDim2.new(0.5, 0, 1, 0); Title.Position = UDim2.new(0, 12, 0, 0); Title.BackgroundTransparency = 1; Title.Text = text; Title.Font = Enum.Font.GothamMedium; AddTheme(Title, "TextColor3", "Muted"); Title.TextSize = 12; Title.TextXAlignment = Enum.TextXAlignment.Left; Title.Parent = TopBtn
				local Status = Instance.new("TextLabel"); Status.Size = UDim2.new(0.5, -30, 1, 0); Status.Position = UDim2.new(0.5, 0, 0, 0); Status.BackgroundTransparency = 1; Status.Text = selected; Status.Font = Enum.Font.GothamBold; AddTheme(Status, "TextColor3", "Text"); Status.TextSize = 12; Status.TextXAlignment = Enum.TextXAlignment.Right; Status.Parent = TopBtn
				local ListContainer = Instance.new("Frame"); ListContainer.Size = UDim2.new(1, 0, 0, 0); ListContainer.Position = UDim2.new(0, 0, 0, 38); AddTheme(ListContainer, "BackgroundColor3", "Bg"); ListContainer.Parent = DropFrame; Instance.new("UICorner", ListContainer).CornerRadius = UDim.new(0, 6)
				local ListLayout = Instance.new("UIListLayout"); ListLayout.SortOrder = Enum.SortOrder.LayoutOrder; ListLayout.Parent = ListContainer

				local function BuildOptions(newOptions)
					for _, v in pairs(ListContainer:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end; options = newOptions
					for _, opt in ipairs(options) do
						local OptBtn = Instance.new("TextButton"); OptBtn.Size = UDim2.new(1, 0, 0, 28); OptBtn.BackgroundTransparency = 1; OptBtn.Text = "  " .. opt; OptBtn.Font = Enum.Font.Gotham; AddTheme(OptBtn, "TextColor3", "Muted"); OptBtn.TextSize = 12; OptBtn.TextXAlignment = Enum.TextXAlignment.Left; OptBtn.Parent = ListContainer
						OptBtn.MouseButton1Click:Connect(function() selected = opt; Status.Text = selected; isOpened = false; TweenService:Create(DropFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 34)}):Play(); if callback then callback(selected) end end)
					end
				end
				BuildOptions(options)

				TopBtn.MouseButton1Click:Connect(function() isOpened = not isOpened; local height = isOpened and (38 + (#options * 28)) or 34; TweenService:Create(DropFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, height)}):Play() end)
				function DDOpts:Refresh(newOptions) BuildOptions(newOptions); if not table.find(newOptions, selected) then selected = newOptions[1] or ""; Status.Text = selected end; if isOpened then TweenService:Create(DropFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 38 + (#newOptions * 28))}):Play() end end
				return DDOpts
			end

			function CardLib:Keybind(text, default, callback)
				local binding = false; local key = default or Enum.KeyCode.F
				local KeyFrame = Instance.new("TextButton"); KeyFrame.Size = UDim2.new(1, 0, 0, 34); KeyFrame.BackgroundTransparency = 1; KeyFrame.Text = ""; KeyFrame.AutoButtonColor = false; KeyFrame.Parent = ItemContainer
				local Label = Instance.new("TextLabel"); Label.Size = UDim2.new(1, -80, 1, 0); Label.BackgroundTransparency = 1; Label.Text = text; Label.Font = Enum.Font.GothamMedium; AddTheme(Label, "TextColor3", "Muted"); Label.TextSize = 12; Label.TextXAlignment = Enum.TextXAlignment.Left; Label.Parent = KeyFrame
				local BindBtn = Instance.new("TextButton"); BindBtn.Size = UDim2.new(0, 60, 0, 22); BindBtn.Position = UDim2.new(1, -60, 0.5, -11); AddTheme(BindBtn, "BackgroundColor3", "Inactive"); BindBtn.Text = key.Name; BindBtn.Font = Enum.Font.GothamBold; AddTheme(BindBtn, "TextColor3", "Text"); BindBtn.TextSize = 11; BindBtn.Parent = KeyFrame; Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 4)

				BindBtn.MouseButton1Click:Connect(function() binding = true; BindBtn.Text = "..." end)
				UserInputService.InputBegan:Connect(function(input) if binding and input.UserInputType == Enum.UserInputType.Keyboard then key = input.KeyCode; BindBtn.Text = key.Name; binding = false; if callback then callback(key) end end end)
			end

			function CardLib:Textbox(text, placeholder, callback)
				local TxtFrame = Instance.new("Frame"); TxtFrame.Size = UDim2.new(1, 0, 0, 34); TxtFrame.BackgroundTransparency = 1; TxtFrame.Parent = ItemContainer
				local Label = Instance.new("TextLabel"); Label.Size = UDim2.new(0.5, 0, 1, 0); Label.BackgroundTransparency = 1; Label.Text = text; Label.Font = Enum.Font.GothamMedium; AddTheme(Label, "TextColor3", "Muted"); Label.TextSize = 12; Label.TextXAlignment = Enum.TextXAlignment.Left; Label.Parent = TxtFrame
				local InputBg = Instance.new("Frame"); InputBg.Size = UDim2.new(0.5, 0, 0, 24); InputBg.Position = UDim2.new(0.5, 0, 0.5, -12); AddTheme(InputBg, "BackgroundColor3", "Inactive"); InputBg.Parent = TxtFrame; Instance.new("UICorner", InputBg).CornerRadius = UDim.new(0, 4); local IStroke = Instance.new("UIStroke"); AddTheme(IStroke, "Color", "Border"); IStroke.Parent = InputBg
				local Box = Instance.new("TextBox"); Box.Size = UDim2.new(1, -10, 1, 0); Box.Position = UDim2.new(0, 5, 0, 0); Box.BackgroundTransparency = 1; Box.Text = ""; Box.PlaceholderText = placeholder or ""; Box.Font = Enum.Font.Gotham; AddTheme(Box, "TextColor3", "Text"); AddTheme(Box, "PlaceholderColor3", "Muted"); Box.TextSize = 11; Box.TextXAlignment = Enum.TextXAlignment.Right; Box.ClearTextOnFocus = false; Box.Parent = InputBg

				Box.FocusLost:Connect(function() if callback then callback(Box.Text) end end)
			end

			return CardLib
		end
		return TabLib
	end

	return WindowLib
end

