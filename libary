local CurrentTheme = "Dark"
local ThemeObjects = {} 

local function AddTheme(instance, property, colorRole)
	table.insert(ThemeObjects, {Inst = instance, Prop = property, Role = colorRole})
	instance[property] = Themes[CurrentTheme][colorRole]
end

Library.UpdateTheme = function(themeName)
	if not Themes[themeName] then return end
	CurrentTheme = themeName
	local t = Themes[themeName]
	for i = #ThemeObjects, 1, -1 do
		local obj = ThemeObjects[i]
		if obj.Inst and obj.Inst.Parent then
			TweenService:Create(obj.Inst, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {[obj.Prop] = t[obj.Role]}):Play()
		else
			table.remove(ThemeObjects, i)
		end
	end
end

local ConfigFolder = "que1s_configs"
local IsStudio = RunService:IsStudio() or not writefile
local StudioMockFiles = {}

if not IsStudio and not isfolder(ConfigFolder) then makefolder(ConfigFolder) end

Library.GetSavedConfigs = function()
	local list = {}
	if IsStudio then
		for name, _ in pairs(StudioMockFiles) do table.insert(list, name) end
	else
		for _, file in ipairs(listfiles(ConfigFolder)) do
			local name = file:match("([^/\\]+)%.txt$") or file:match("([^/\\]+)$")
			if name then table.insert(list, name) end
		end
	end
	if #list == 0 then table.insert(list, "Default") end
	return list
end

Library.SaveFile = function(name, data)
	if IsStudio then StudioMockFiles[name] = data else writefile(ConfigFolder .. "/" .. name .. ".txt", data) end
end

Library.DeleteFile = function(name)
	if IsStudio then StudioMockFiles[name] = nil else local path = ConfigFolder .. "/" .. name .. ".txt"; if isfile(path) then delfile(path) end end
end

